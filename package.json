{
  "name": "pesisselostaja",
  "version": "1.0.0",
  "description": "Web app for following Finnish pesäpallo live events with spoken voice announcements",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node apps/server/dist/index.js",
    "relay:dev": "npm run dev -w @pesisselostaja/broadcast --",
    "relay:simulate": "npm run simulate -w @pesisselostaja/broadcast --",
    "relay:flap-test": "npm run flap-test -w @pesisselostaja/broadcast --",
    "relay:typecheck": "npm run typecheck -w @pesisselostaja/broadcast",
    "relay:lint": "npm run lint -w @pesisselostaja/broadcast",
    "broadcast:dev": "npm run dev -w @pesisselostaja/broadcast --",
    "broadcast:simulate": "npm run simulate -w @pesisselostaja/broadcast --",
    "broadcast:flap-test": "npm run flap-test -w @pesisselostaja/broadcast --",
    "broadcast:typecheck": "npm run typecheck -w @pesisselostaja/broadcast",
    "broadcast:lint": "npm run lint -w @pesisselostaja/broadcast"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
