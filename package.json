{
  "name": "pesistulokset-voice-watcher",
  "version": "1.0.0",
  "description": "Watch Finnish pesäpallo matches live and speak events through Home Assistant TTS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/ test/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
