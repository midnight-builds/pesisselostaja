# Copy to relay/.env.relay and fill in real values. Never commit relay/.env.relay
# (it holds a YouTube stream key). Values below are fictional placeholders.

# Same pesistulokset.fi match ID the main app watches.
RELAY_MATCH_ID=123456

# Public watch URL of the ORIGINAL livestream (the phone's own YouTube broadcast).
# This broadcast is never touched — the relay only reads it.
RELAY_YOUTUBE_URL=https://www.youtube.com/watch?v=xxxxxxxxxxx

# RTMP ingest for the SECOND ("commentated") broadcast. Create this broadcast
# manually in YouTube Studio first and copy its ingest URL + stream key here.
RELAY_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
RELAY_STREAM_KEY=xxxx-xxxx-xxxx-xxxx-xxxx

# Optional overrides (defaults shown):
# RELAY_VOICE=harri-medium
# RELAY_PIPER_BIN=piper
# RELAY_POLL_INTERVAL=6000
# RELAY_NARRATION_GAIN=1.3
# RELAY_DRY_RUN=false
# PESISTULOKSET_API_KEY=
# PESISTULOKSET_API_BASE=
